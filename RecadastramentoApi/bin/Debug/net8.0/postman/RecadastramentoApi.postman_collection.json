{
  "info": {
    "_postman_id": "2ae2d062-3f47-43df-a5d1-e553ddf0f310",
    "name": "Recadastramento API - Personas",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection para testar a API de personas com autenticação por prefeitura (ClientId + ApiKey) e rota por cidade."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5090"
    },
    {
      "key": "cidade",
      "value": "cidade-exemplo"
    },
    {
      "key": "clientId",
      "value": "prefeitura-exemplo"
    },
    {
      "key": "apiKey",
      "value": "TroqueEssaChaveForte2026!"
    },
    {
      "key": "cpf",
      "value": "12345678901"
    },
    {
      "key": "uf",
      "value": "MA"
    }
  ],
  "item": [
    {
      "name": "Personas",
      "item": [
        {
          "name": "POST Upsert em lote",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Client-Id",
                "value": "{{clientId}}",
                "type": "text"
              },
              {
                "key": "X-Api-Key",
                "value": "{{apiKey}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"cpf\": \"12345678901\",\n    \"nome\": \"Joao da Silva\",\n    \"sexo_enum\": 1,\n    \"etnia_enum\": 1,\n    \"nacionalidade_enum\": 10,\n    \"nacionalidade_pais\": 105,\n    \"def_fisica\": 0,\n    \"def_visual\": 0,\n    \"def_auditiva\": 0,\n    \"def_mental\": 0,\n    \"def_intelectual\": 0,\n    \"def_reabilitado\": 0,\n    \"def_cota\": 0,\n    \"digital_ok\": false,\n    \"uf\": \"MA\",\n    \"municipio_id\": 1001,\n    \"digital_hstore01\": {\n      \"fonte\": \"postman\",\n      \"versao\": \"1\"\n    }\n  },\n  {\n    \"cpf\": \"22222222222\",\n    \"nome\": \"Maria Souza\",\n    \"sexo_enum\": 2,\n    \"etnia_enum\": 1,\n    \"nacionalidade_enum\": 10,\n    \"nacionalidade_pais\": 105,\n    \"def_fisica\": 0,\n    \"def_visual\": 0,\n    \"def_auditiva\": 0,\n    \"def_mental\": 0,\n    \"def_intelectual\": 0,\n    \"def_reabilitado\": 0,\n    \"def_cota\": 0,\n    \"digital_ok\": false,\n    \"uf\": \"MA\",\n    \"municipio_id\": 1001\n  }\n]"
            },
            "url": {
              "raw": "{{baseUrl}}/{{cidade}}/personas",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{cidade}}",
                "personas"
              ]
            },
            "description": "Faz upsert por CPF para cada item da lista (insere se nao existe, atualiza se existe)."
          },
          "response": []
        },
        {
          "name": "GET Listar personas (com filtros)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Client-Id",
                "value": "{{clientId}}",
                "type": "text"
              },
              {
                "key": "X-Api-Key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/{{cidade}}/personas?uf={{uf}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{cidade}}",
                "personas"
              ],
              "query": [
                {
                  "key": "uf",
                  "value": "{{uf}}"
                }
              ]
            },
            "description": "Sem paginacao. Filtros suportados: cpf, nome, municipio_id, uf, fkrecadastramento, recad_status."
          },
          "response": []
        },
        {
          "name": "GET Buscar por CPF",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Client-Id",
                "value": "{{clientId}}",
                "type": "text"
              },
              {
                "key": "X-Api-Key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/{{cidade}}/personas/{{cpf}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{cidade}}",
                "personas",
                "{{cpf}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET Export JSON",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Client-Id",
                "value": "{{clientId}}",
                "type": "text"
              },
              {
                "key": "X-Api-Key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/{{cidade}}/personas/export?format=json",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{cidade}}",
                "personas",
                "export"
              ],
              "query": [
                {
                  "key": "format",
                  "value": "json"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET Export CSV",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Client-Id",
                "value": "{{clientId}}",
                "type": "text"
              },
              {
                "key": "X-Api-Key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/{{cidade}}/personas/export?format=csv",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{cidade}}",
                "personas",
                "export"
              ],
              "query": [
                {
                  "key": "format",
                  "value": "csv"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET Export XLSX",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Client-Id",
                "value": "{{clientId}}",
                "type": "text"
              },
              {
                "key": "X-Api-Key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/{{cidade}}/personas/export?format=xlsx",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{cidade}}",
                "personas",
                "export"
              ],
              "query": [
                {
                  "key": "format",
                  "value": "xlsx"
                }
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
